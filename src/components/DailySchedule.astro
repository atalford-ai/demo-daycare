---
import config from '../../site.json';
const schedule = config.daily_schedule;
---
<section id="schedule" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16">
      <span class="badge badge-accent badge-lg rounded-full text-xs tracking-widest uppercase mb-4">A Day at Little Stars</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Daily Schedule</h2>
      <p class="text-base-content/60 mt-4 max-w-lg mx-auto">A structured yet flexible day that balances learning, play, rest, and fun.</p>
    </div>

    <div class="max-w-2xl mx-auto">
      <ul class="steps steps-vertical w-full">
        {schedule.map((item, index) => (
          <li class={`step ${index <= 4 ? 'step-primary' : index <= 7 ? 'step-secondary' : 'step-accent'}`} data-content={index + 1}>
            <div class="text-left py-4 pl-2">
              <div class="flex items-center gap-3 mb-1">
                <span class="badge badge-sm rounded-full font-mono">{item.time}</span>
                <span class="font-heading font-bold text-lg">{item.activity}</span>
              </div>
              <p class="text-base-content/60 text-sm ml-1">{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
