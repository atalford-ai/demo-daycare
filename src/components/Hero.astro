---
import config from '../../site.json';
---
<section class="hero min-h-[90vh] bg-gradient-to-br from-primary/10 via-secondary/10 to-accent/10">
  <div class="hero-content text-center flex-col py-24">
    <!-- Floating decorative badges -->
    <div class="relative w-full max-w-4xl">
      <div class="absolute -top-8 left-8 hidden md:block animate-bounce" style="animation-duration: 3s;">
        <span class="badge badge-primary badge-lg rounded-full shadow-lg">Ages 6wk-5yr</span>
      </div>
      <div class="absolute -top-4 right-12 hidden md:block animate-bounce" style="animation-duration: 4s; animation-delay: 0.5s;">
        <span class="badge badge-secondary badge-lg rounded-full shadow-lg">Licensed</span>
      </div>
      <div class="absolute top-16 -left-4 hidden md:block animate-bounce" style="animation-duration: 3.5s; animation-delay: 1s;">
        <span class="badge badge-accent badge-lg rounded-full shadow-lg">Safe & Secure</span>
      </div>
      <div class="absolute top-20 -right-2 hidden md:block animate-bounce" style="animation-duration: 4.5s; animation-delay: 0.3s;">
        <span class="badge badge-info badge-lg rounded-full shadow-lg">Nurturing</span>
      </div>

      <!-- Main hero content -->
      <div class="max-w-2xl mx-auto">
        <span class="badge badge-primary badge-lg text-xs tracking-widest uppercase mb-6 rounded-full">Now Enrolling</span>
        <h1 class="text-5xl md:text-7xl font-heading font-bold leading-tight mb-6">
          Where Little Ones<br /><span class="text-primary">Shine Bright!</span>
        </h1>
        <p class="text-lg text-base-content/70 max-w-md mx-auto mb-10">
          {config.description}
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="#enrollment" class="btn btn-primary btn-lg rounded-full px-10 shadow-lg">
            Enroll Today
          </a>
          <a href="#programs" class="btn btn-outline btn-secondary btn-lg rounded-full px-10">
            Our Programs
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex items-center justify-center gap-6 mt-12">
          <div class="flex -space-x-3">
            <div class="avatar">
              <div class="w-10 rounded-full ring ring-primary ring-offset-base-100 ring-offset-1">
                <img src="https://images.unsplash.com/photo-1595003969974-1e5fcc61d5e0?w=80&h=80&fit=crop" alt="Happy child" />
              </div>
            </div>
            <div class="avatar">
              <div class="w-10 rounded-full ring ring-secondary ring-offset-base-100 ring-offset-1">
                <img src="https://images.unsplash.com/photo-1503919545889-aef636e10ad4?w=80&h=80&fit=crop" alt="Happy child" />
              </div>
            </div>
            <div class="avatar">
              <div class="w-10 rounded-full ring ring-accent ring-offset-base-100 ring-offset-1">
                <img src="https://images.unsplash.com/photo-1471286174890-9c112ffca5b4?w=80&h=80&fit=crop" alt="Happy child" />
              </div>
            </div>
          </div>
          <p class="text-sm text-base-content/60">Trusted by <span class="font-semibold text-base-content">100+ families</span> in Atlanta</p>
        </div>
      </div>
    </div>
  </div>
</section>
