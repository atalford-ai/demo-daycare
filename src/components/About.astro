---
import config from '../../site.json';

const facilityImages = [
  { src: "https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=800&h=500&fit=crop", alt: "Colorful classroom" },
  { src: "https://images.unsplash.com/photo-1587654780293-48f9a77f2d1c?w=800&h=500&fit=crop", alt: "Children playing" },
  { src: "https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=800&h=500&fit=crop", alt: "Outdoor playground" },
  { src: "https://images.unsplash.com/photo-1544776193-352d25ca82cd?w=800&h=500&fit=crop", alt: "Learning activities" },
];

const values = [
  { label: "Safety First", color: "badge-primary" },
  { label: "Creativity", color: "badge-secondary" },
  { label: "Diversity", color: "badge-accent" },
  { label: "Nurturing", color: "badge-info" },
  { label: "Play-Based", color: "badge-success" },
  { label: "Community", color: "badge-warning" },
];
---
<section id="about" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16">
      <span class="badge badge-info badge-lg rounded-full text-xs tracking-widest uppercase mb-4">Our Story</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Where Every Child <span class="text-primary">Belongs</span></h2>
      <p class="text-base-content/60 mt-4 max-w-2xl mx-auto text-lg">
        Little Stars was founded with a simple belief: every child deserves a safe, joyful space to grow. Our center blends structured learning with creative play, giving children the foundation they need to thrive.
      </p>
    </div>

    <!-- Carousel -->
    <div class="carousel carousel-center w-full max-w-3xl mx-auto rounded-3xl overflow-hidden shadow-xl mb-12 h-72 md:h-96">
      {facilityImages.map((img, index) => (
        <div class="carousel-item w-full" id={`about-slide-${index}`}>
          <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
        </div>
      ))}
    </div>

    <!-- Carousel navigation -->
    <div class="flex justify-center gap-2 mb-12">
      {facilityImages.map((_, index) => (
        <a href={`#about-slide-${index}`} class="btn btn-circle btn-sm btn-primary btn-outline rounded-full">{index + 1}</a>
      ))}
    </div>

    <!-- Values -->
    <div class="text-center">
      <h3 class="font-heading font-bold text-xl mb-6">Our Values</h3>
      <div class="flex flex-wrap gap-3 justify-center">
        {values.map((value) => (
          <span class={`badge ${value.color} badge-lg rounded-full px-5 py-3 text-sm font-medium`}>{value.label}</span>
        ))}
      </div>
    </div>

    <!-- Extra paragraph -->
    <p class="text-base-content/60 text-center mt-8 max-w-xl mx-auto">
      From our warm, colorful classrooms to our outdoor play spaces, everything is designed with your child's well-being in mind.
    </p>
  </div>
</section>
