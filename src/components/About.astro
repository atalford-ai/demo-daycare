---
import config from '../../site.json';
---
<section id="about" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Image -->
      <div class="fade-in-up">
        <div class="bg-base-200 rounded-3xl aspect-[4/3] overflow-hidden border border-base-300/50">
          <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=800&h=600&fit=crop" alt="Little Stars daycare facility" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>

      <!-- Text -->
      <div class="fade-in-up" style="animation-delay: 0.2s;">
        <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Our Story</span>
        <h2 class="text-4xl md:text-5xl font-heading font-bold mb-6">Where Every Child<br /><span class="text-accent">Belongs</span></h2>
        <p class="text-base-content/70 text-lg leading-relaxed mb-6">
          Little Stars was founded with a simple belief: every child deserves a safe, joyful space to grow. Our center blends structured learning with creative play, giving children the foundation they need to thrive.
        </p>
        <p class="text-base-content/70 text-lg leading-relaxed mb-8">
          From our warm, colorful classrooms to our outdoor play spaces, everything is designed with your child's well-being in mind.
        </p>

        <div class="grid grid-cols-3 gap-6">
          <div class="text-center">
            <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <p class="font-heading font-semibold">Safety First</p>
            <p class="text-xs text-base-content/50 mt-1">Licensed & inspected</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <p class="font-heading font-semibold">Creativity</p>
            <p class="text-xs text-base-content/50 mt-1">Art, music & play</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p class="font-heading font-semibold">Diversity</p>
            <p class="text-xs text-base-content/50 mt-1">Inclusive community</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
