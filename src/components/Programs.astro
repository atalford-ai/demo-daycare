---
import config from '../../site.json';
const programs = config.programs;
---
<section id="programs" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Our Programs</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Programs for Every Stage</h2>
      <p class="text-base-content/60 mt-4 max-w-lg mx-auto">Age-appropriate care and curriculum designed to nurture your child's growth at every milestone.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
      {programs.map((program) => (
        <div class="card bg-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <figure class="relative aspect-[4/3] overflow-hidden">
            <img src={program.image} alt={program.name} class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute top-3 right-3">
              <span class="badge badge-accent text-xs font-medium">{program.age_range}</span>
            </div>
          </figure>
          <div class="card-body">
            <h3 class="card-title font-heading">{program.name}</h3>
            <p class="text-base-content/70 text-sm">{program.description}</p>
            <ul class="mt-3 space-y-1">
              {program.features.map((feature: string) => (
                <li class="flex items-center gap-2 text-sm text-base-content/60">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <div class="card-actions justify-between items-center mt-4">
              <span class="text-lg font-heading font-bold text-accent">{program.tuition}</span>
              <a href="#enrollment" class="btn btn-accent btn-sm">Enroll</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
