---
import config from '../../site.json';
const programs = config.programs;
const borderColors = ['border-t-primary', 'border-t-secondary', 'border-t-accent', 'border-t-info'];
---
<section id="programs" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16">
      <span class="badge badge-primary badge-lg rounded-full text-xs tracking-widest uppercase mb-4">Our Programs</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Programs for Every Stage</h2>
      <p class="text-base-content/60 mt-4 max-w-lg mx-auto">Age-appropriate care and curriculum designed to nurture your child's growth at every milestone.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {programs.map((program, index) => (
        <div class={`card card-bordered bg-base-100 rounded-3xl border-t-4 ${borderColors[index % borderColors.length]} shadow-md hover:shadow-xl transition-all duration-300`}>
          <div class="card-body">
            <div class="flex items-center justify-between mb-2">
              <h3 class="card-title font-heading text-xl">{program.name}</h3>
              <span class="badge badge-outline rounded-full">{program.age_range}</span>
            </div>
            <p class="text-base-content/70">{program.description}</p>

            <div class="divider"></div>

            <ul class="space-y-2">
              {program.features.map((feature: string) => (
                <li class="flex items-center gap-3 text-sm text-base-content/80">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <div class="card-actions justify-between items-center mt-6">
              <span class="text-xl font-heading font-bold text-primary">{program.tuition}</span>
              <a href="#enrollment" class="btn btn-primary btn-sm rounded-full px-6">Enroll</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
