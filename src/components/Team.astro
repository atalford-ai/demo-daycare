---
import config from '../../site.json';
const team = config.team;
---
<section id="team" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto">
    <div class="text-center mb-16">
      <span class="badge badge-secondary badge-lg rounded-full text-xs tracking-widest uppercase mb-4">Our Team</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Meet Our Caregivers</h2>
      <p class="text-base-content/60 mt-4 max-w-lg mx-auto">Experienced, certified, and passionate about giving your child the best start in life.</p>
    </div>

    <div class="max-w-4xl mx-auto space-y-12">
      {team.map((member, index) => (
        <div class="flex flex-col items-center gap-4">
          <!-- Avatar -->
          <div class="avatar">
            <div class="w-24 rounded-full ring ring-primary ring-offset-base-100 ring-offset-3">
              <img src={member.image} alt={member.name} loading="lazy" />
            </div>
          </div>

          <!-- Name and role -->
          <div class="text-center">
            <h3 class="font-heading font-bold text-lg">{member.name}</h3>
            <p class="text-primary font-medium text-sm">{member.role}</p>
            <span class="badge badge-outline badge-sm rounded-full mt-1">{member.certification}</span>
          </div>

          <!-- Chat bubble with quote -->
          <div class={`chat ${index % 2 === 0 ? 'chat-start' : 'chat-end'} w-full max-w-md`}>
            <div class="chat-image avatar">
              <div class="w-10 rounded-full">
                <img src={member.image} alt={member.name} />
              </div>
            </div>
            <div class="chat-header">
              {member.name.split(' ').pop()}
            </div>
            <div class="chat-bubble chat-bubble-primary rounded-3xl">
              {member.bio}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
