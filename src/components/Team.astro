---
import config from '../../site.json';
const team = config.team;
---
<section id="team" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Our Team</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Meet Our Caregivers</h2>
      <p class="text-base-content/60 mt-4 max-w-lg mx-auto">Experienced, certified, and passionate about giving your child the best start in life.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
      {team.map((member) => (
        <div class="card bg-base-100 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center">
          <figure class="px-6 pt-6">
            <div class="avatar">
              <div class="w-32 rounded-full ring ring-accent ring-offset-base-100 ring-offset-2">
                <img src={member.image} alt={member.name} loading="lazy" />
              </div>
            </div>
          </figure>
          <div class="card-body items-center">
            <h3 class="card-title font-heading text-lg">{member.name}</h3>
            <p class="text-accent font-medium text-sm">{member.role}</p>
            <div class="badge badge-outline badge-sm mt-1">{member.certification}</div>
            <p class="text-base-content/60 text-sm mt-2">{member.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
