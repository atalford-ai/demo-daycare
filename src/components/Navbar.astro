---
import config from '../../site.json';
---
<header class="navbar bg-base-100/80 backdrop-blur-md sticky top-0 z-50 border-b border-base-300/50">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost text-xl font-heading font-bold tracking-tight">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span class="text-accent">Little</span> Stars
    </a>
  </div>

  <nav class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-4">
      <li><a href="#programs" class="font-medium text-base tracking-wide">Programs</a></li>
      <li><a href="#schedule" class="font-medium text-base tracking-wide">Daily Schedule</a></li>
      <li><a href="#team" class="font-medium text-base tracking-wide">Our Team</a></li>
      <li><a href="#about" class="font-medium text-base tracking-wide">About</a></li>
      <li><a href="#enrollment" class="font-medium text-base tracking-wide">Enroll</a></li>
      <li><a href="#contact" class="font-medium text-base tracking-wide">Contact</a></li>
    </ul>
  </nav>

  <div class="navbar-end gap-2">
    <a href="#enrollment" class="btn btn-accent btn-sm hidden lg:inline-flex">Enroll Now</a>

    <!-- Mobile menu -->
    <div class="dropdown dropdown-end lg:hidden">
      <label tabindex="0" class="btn btn-ghost btn-circle">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
      </label>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-lg bg-base-200 rounded-box w-52">
        <li><a href="#programs">Programs</a></li>
        <li><a href="#schedule">Daily Schedule</a></li>
        <li><a href="#team">Our Team</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#enrollment">Enroll</a></li>
        <li><a href="#contact">Contact</a></li>
        <li class="mt-2"><a href="#enrollment" class="btn btn-accent btn-sm">Enroll Now</a></li>
      </ul>
    </div>
  </div>
</header>
